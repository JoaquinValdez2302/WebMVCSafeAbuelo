@model IEnumerable<WebMVCSafeAbuelo.Models.MetodologiaAtaque>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

@if (User.IsInRole("Administrador"))
{
    <p><a asp-action="Create">Create New</a></p>
}
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nombre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Descripcion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PrincipalMotorPsicologico)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SeñalesDeAlarma)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AccionPreventiva)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EstaActivo)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Nombre)
            </td>
            <td>
                @Html.DisplayFor(model => item.Descripcion)
            </td>
            <td>
                @Html.DisplayFor(model => item.PrincipalMotorPsicologico)
            </td>
            <td>
                @Html.DisplayFor(model => item.SeñalesDeAlarma)
            </td>
            <td>
                @Html.DisplayFor(model => item.AccionPreventiva)
            </td>
            <td>
                @Html.DisplayFor(model => item.EstaActivo)
            </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Detalles</a>

                    @if (User.IsInRole("Administrador"))
                    {
                        <text> | </text>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <text> | </text>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    }
                </td>
        </tr>
}
    </tbody>
</table>
