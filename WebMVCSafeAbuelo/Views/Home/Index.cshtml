@model WebMVCSafeAbuelo.ViewModels.HomeIndexViewModel

<div class="container mt-4">
    <h2 class="mb-4" style="color: var(--clr-primary-dark);">Resumen de Actividad</h2>

    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="card-panel border-left-primary h-100 text-center">
                <h6 class="text-muted text-uppercase fw-bold mb-2">Total de Reportes</h6>
                <h2 class="text-primary fw-bold mb-3">@Model.TotalReportes</h2>
                <span class="badge-aceptado px-2 py-1 rounded-pill text-sm">
                    <i class="bi bi-arrow-up-short"></i> Actualizado hoy
                </span>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card-panel border-left-warning h-100 text-center">
                <h6 class="text-muted text-uppercase fw-bold mb-2">En Revisión</h6>
                <h2 class="text-warning fw-bold mb-3">@Model.ReportesPendientes</h2>
                <span class="badge-pendiente px-2 py-1 rounded-pill text-sm">
                    Requieren atención
                </span>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card-panel border-left-danger h-100 text-center">
                <h6 class="text-muted text-uppercase fw-bold mb-2">Fraudes Confirmados</h6>
                <h2 class="text-danger fw-bold mb-3">@Model.FraudesConfirmados</h2>
                <span class="badge-rechazado px-2 py-1 rounded-pill text-sm">
                    Alta prioridad
                </span>
            </div>
        </div>
    </div>

    <div class="mt-5">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <h3 class="fw-bold mb-1" style="color: var(--clr-primary-dark);">Alertas en tu Zona</h3>
                <p class="text-muted mb-0">Casos validados recientemente para tu prevención.</p>
            </div>
            <a asp-controller="ReporteIncidentes" asp-action="Index" class="btn btn-outline-primary btn-sm px-3 rounded-pill">
                Ver historial completo
            </a>
        </div>

        <div class="row">
            @if (!Model.AlertasRecientes.Any())
            {
                <div class="col-12 text-center py-5">
                    <i class="bi bi-shield-check text-success" style="font-size: 3rem;"></i>
                    <h5 class="mt-3 fw-bold text-primary">Todo tranquilo por ahora</h5>
                    <p class="text-muted">No hay alertas confirmadas recientes en la zona. ¡Mantente seguro!</p>
                </div>
            }
            else
            {
                @foreach (var alerta in Model.AlertasRecientes)
                {
                    <div class="col-md-6 mb-4">
                        <div class="card-panel h-100 d-flex flex-column @(alerta.GeneraSentidoDeUrgencia ? "border-left-danger" : "border-left-warning")">

                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <span class="badge bg-primary px-3 py-2 rounded-pill text-sm shadow-sm">
                                    @alerta.PlataformaDeContacto.ToString()
                                </span>
                                <small class="text-muted fw-bold">@alerta.FechaReporte.ToString("dd/MM/yyyy")</small>
                            </div>

                            <h5 class="text-primary fw-bold mb-2">
                                <i class="bi bi-geo-alt-fill text-danger me-1"></i> @alerta.Localidad.ToString(), @alerta.Provincia.ToString()
                            </h5>

                            <p class="mb-4 text-muted flex-grow-1" style="line-height: 1.6;">
                                "@alerta.DescripcionDelEngaño"
                            </p>

                            <div class="mt-auto border-top pt-3">
                                @if (alerta.GeneraSentidoDeUrgencia)
                                {
                                    <span class="badge badge-rechazado px-2 py-1 rounded-pill text-sm me-2">
                                        <i class="bi bi-exclamation-triangle-fill"></i> Exige acción urgente
                                    </span>
                                }
                                @if (alerta.EjercePresionPsicologica)
                                {
                                    <span class="badge badge-pendiente px-2 py-1 rounded-pill text-sm">
                                        Presión psicológica
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>