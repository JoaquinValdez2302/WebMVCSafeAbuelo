@model WebMVCSafeAbuelo.Models.ReporteIncidente

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>ReporteIncidente</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="FechaReporte" class="control-label"></label>
                <input asp-for="FechaReporte" class="form-control" />
                <span asp-validation-for="FechaReporte" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Provincia" class="control-label fw-bold">Provincia</label>
                <select asp-for="Provincia" class="form-select" id="provinciaSelect" asp-items="Html.GetEnumSelectList<WebMVCSafeAbuelo.Models.Provincia>()">
                    <option value="">-- Seleccione una provincia --</option>
                </select>
                <span asp-validation-for="Provincia" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Localidad" class="control-label fw-bold">Localidad</label>
                <!-- Le quitamos el asp-items porque lo llenaremos con JavaScript -->
                <select asp-for="Localidad" class="form-select" id="localidadSelect" disabled>
                    <option value="">-- Primero seleccione una provincia --</option>
                </select>
                <span asp-validation-for="Localidad" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PlataformaDeContacto" class="control-label fw-bold">Plataforma de Contacto</label>
                <select asp-for="PlataformaDeContacto" class="form-select" id="plataformaSelect" asp-items="Html.GetEnumSelectList<WebMVCSafeAbuelo.Models.PlataformaContacto>()">
                    <option value="">-- Seleccione una plataforma --</option>
                </select>
                <span asp-validation-for="PlataformaDeContacto" class="text-danger"></span>
            </div>

            <div class="form-group mb-3" id="divPlataformaOtra" style="display: none;">
                <label asp-for="PlataformaOtra" class="control-label fw-bold">Especifique la plataforma</label>
                <input asp-for="PlataformaOtra" id="inputPlataformaOtra" class="form-control" placeholder="Ej: Telegram, Tinder..." />
                <span asp-validation-for="PlataformaOtra" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="EjercePresionPsicologica" class="control-label"></label>
                <input asp-for="EjercePresionPsicologica" class="form-check-input" />
                <span asp-validation-for="EjercePresionPsicologica" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="GeneraSentidoDeUrgencia" class="control-label"></label>
                <input asp-for="GeneraSentidoDeUrgencia" class="form-check-input" />
                <span asp-validation-for="GeneraSentidoDeUrgencia" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DescripcionDelEngaño" class="control-label"></label>
                <input asp-for="DescripcionDelEngaño" class="form-control" />
                <span asp-validation-for="DescripcionDelEngaño" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Estado" class="control-label fw-bold">Estado del Reporte</label>
                <select asp-for="Estado" class="form-select" asp-items="Html.GetEnumSelectList<WebMVCSafeAbuelo.Models.EstadoIncidente>()">
                    <option value="">-- Seleccione un estado --</option>
                </select>
                <span asp-validation-for="Estado" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const select = document.getElementById("plataformaSelect");
            const divOtra = document.getElementById("divPlataformaOtra");
            const inputOtra = document.getElementById("inputPlataformaOtra");

            function verificarSeleccion() {
                // Obtenemos el texto de la opción que el usuario seleccionó
                const textoSeleccionado = select.options[select.selectedIndex].text;

                if (textoSeleccionado === "Otro") {
                    // Si es "Otro", mostramos la caja de texto
                    divOtra.style.display = "block";
                } else {
                    // Si es cualquier otra cosa, la ocultamos y borramos lo que hayan escrito
                    divOtra.style.display = "none";
                    inputOtra.value = "";
                }
            }

            // Escuchar cada vez que el usuario cambia de opción
            select.addEventListener("change", verificarSeleccion);
        });

                document.addEventListener("DOMContentLoaded", function () {
            const provinciaSelect = document.getElementById("provinciaSelect");
            const localidadSelect = document.getElementById("localidadSelect");

            // Diccionario con las opciones: La clave (0 o 1) corresponde al valor numérico del Enum Provincia
            // 0 = Corrientes, 1 = Chaco.
            // En los values de adentro: 0 = Corrientes (Localidad), 1 = Resistencia (Localidad)
            const opcionesLocalidad = {
                "0": [{ valor: "0", texto: "Corrientes" }],
                "1": [{ valor: "1", texto: "Resistencia" }]
            };

            provinciaSelect.addEventListener("change", function () {
                const provinciaId = this.value;

                // Limpiamos el selector de localidades
                localidadSelect.innerHTML = '<option value="">-- Seleccione una localidad --</option>';

                if (provinciaId && opcionesLocalidad[provinciaId]) {
                    // Habilitamos el selector
                    localidadSelect.disabled = false;

                    // Insertamos las opciones que corresponden a esa provincia
                    opcionesLocalidad[provinciaId].forEach(loc => {
                        const option = document.createElement("option");
                        option.value = loc.valor;
                        option.textContent = loc.texto;
                        localidadSelect.appendChild(option);
                    });
                } else {
                    // Si deseleccionan la provincia, volvemos a bloquear la localidad
                    localidadSelect.disabled = true;
                }
            });
        });
    </script>
}