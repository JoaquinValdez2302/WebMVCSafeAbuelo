@model IEnumerable<WebMVCSafeAbuelo.Models.ReporteIncidente>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="buscar" value="@ViewBag.Buscar" class="form-control" placeholder="Buscar por localidad, engaño o plataforma..." />
        <button type="submit" class="btn btn-primary">🔍 Buscar</button>
        <a asp-action="Index" class="btn btn-secondary">Limpiar</a>
    </div>
</form>
<table class="table-custom">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.FechaReporte)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Localidad)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PlataformaDeContacto)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EjercePresionPsicologica)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.GeneraSentidoDeUrgencia)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DescripcionDelEngaño)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Estado)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.FechaReporte)
            </td>
            <td>
                @Html.DisplayFor(model => item.Localidad)
            </td>
            <td>
                @Html.DisplayFor(model => item.PlataformaDeContacto)
            </td>
            <td>
                @Html.DisplayFor(model => item.EjercePresionPsicologica)
            </td>
            <td>
                @Html.DisplayFor(model => item.GeneraSentidoDeUrgencia)
            </td>
            <td>
                @Html.DisplayFor(model => item.DescripcionDelEngaño)
            </td>
            <td>
                @Html.DisplayFor(model => item.Estado)
            </td>
            <td>
                @if (User.IsInRole("Administrador"))
                    {
                        <text>
                            <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                            <a asp-action="Details" class="btn btn-sm btn-outline-info" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>

                </text>
                }
                    <a asp-controller="EvidenciaIncidentes" asp-action="Index" asp-route-reporteId="@item.Id" class="btn btn-sm btn-info text-white">
                        Ver Evidencias
                    </a>
            </td>
        </tr>
}
    </tbody>
</table>
<nav aria-label="Navegación de incidentes">
    <ul class="pagination justify-content-center mt-4">

        <li class="page-item @(ViewBag.PaginaActual == 1 ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-pagina="@(ViewBag.PaginaActual - 1)" asp-route-buscar="@ViewBag.Buscar">
                Anterior
            </a>
        </li>

        @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
        {
            <li class="page-item @(i == ViewBag.PaginaActual ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-pagina="@i" asp-route-buscar="@ViewBag.Buscar">@i</a>
            </li>
        }

        <li class="page-item @(ViewBag.PaginaActual == ViewBag.TotalPaginas ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-pagina="@(ViewBag.PaginaActual + 1)" asp-route-buscar="@ViewBag.Buscar">
                Siguiente
            </a>
        </li>

    </ul>
</nav>