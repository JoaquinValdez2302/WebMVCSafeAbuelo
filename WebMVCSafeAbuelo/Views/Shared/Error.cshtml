@model WebMVCSafeAbuelo.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container text-center mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h2 class="mb-0">@ViewBag.ErrorTitle</h2>
                </div>
                <div class="card-body">
                    <h5 class="card-title text-danger mb-4">
                        <i class="bi bi-exclamation-triangle-fill" style="font-size: 3rem;"></i>
                    </h5>
                    <p class="card-text lead">@ViewBag.ErrorMessage</p>

                    @if (Model.ShowRequestId)
                    {
                        <p class="text-muted small mt-4">
                            <strong>ID de Seguimiento (Para soporte técnico):</strong> <code>@Model.RequestId</code>
                        </p>
                    }

                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
                        Volver al Inicio
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>