@model IEnumerable<WebMVCSafeAbuelo.Models.EvidenciaIncidente>

@{
    ViewData["Title"] = "Expediente de Evidencias";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            Anexos del Expediente
            <span class="badge bg-secondary">Caso #@ViewBag.ReporteId</span>
        </h2>
    </div>

    <div class="mb-4">
        @if (User.IsInRole("Administrador"))
        {
            <a asp-action="Create" asp-route-reporteId="@ViewBag.ReporteId" class="btn btn-primary shadow-sm">
                <strong>+</strong> Agregar Nueva Evidencia
            </a>
        }

        <a asp-controller="ReporteIncidentes" asp-action="Index" class="btn btn-outline-secondary shadow-sm ms-2">
            Volver a la Base Principal
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.Tipo)</th>
                        <th>@Html.DisplayNameFor(model => model.Valor)</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">
                                <em>No hay evidencias registradas en este expediente todavía.</em>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle">
                                    <strong>@Html.DisplayFor(modelItem => item.Tipo)</strong>
                                </td>
                                <td class="align-middle">
                                    <span class="text-break">@Html.DisplayFor(modelItem => item.Valor)</span>
                                </td>
                                <td class="text-end align-middle">
                                    @if (User.IsInRole("Administrador"))
                                    {
                                        <div class="btn-group" role="group">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Detalles</a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
