@model WebMVCSafeAbuelo.Models.EvidenciaIncidente

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>EvidenciaIncidente</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Tipo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Tipo)
        </dd>
    </dl>
    <dl>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Valor)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Valor)
        </dd>
    </dl>
   
    <dl>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ReporteIncidenteId)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ReporteIncidenteId)
        </dd>
    </dl>
    <dl>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ReporteIncidente)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ReporteIncidente)
        </dd>
    </dl>
</div>
<div>
    @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Administrador"))
    {
        <text>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Editar</a> |
        </text>
    }

    <a asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
</div>
