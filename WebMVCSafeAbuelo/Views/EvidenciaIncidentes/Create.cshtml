@model WebMVCSafeAbuelo.Models.EvidenciaIncidente

@{
    ViewData["Title"] = "Agregar Evidencia";
}

<div class="container mt-4">
    <h2>Agregar Anexo al Expediente <span class="badge bg-secondary">Caso #@ViewBag.ReporteId</span></h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="Tipo" class="control-label fw-bold">Clasificación de la Evidencia</label>
                    <select asp-for="Tipo" class="form-select" asp-items="Html.GetEnumSelectList<WebMVCSafeAbuelo.Models.TipoEvidencia>()">
                        <option value="">-- Seleccione una categoría --</option>
                    </select>
                    <span asp-validation-for="Tipo" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Valor" class="control-label fw-bold">Dato o Contenido</label>
                    <input asp-for="Valor" class="form-control" placeholder="Ej: +54 379... o URL maliciosa" />
                    <span asp-validation-for="Valor" class="text-danger"></span>
                </div>

                <input type="hidden" asp-for="ReporteIncidenteId" value="@ViewBag.ReporteId" />

                <div class="form-group mt-4">
                    <input type="submit" value="Guardar en Expediente" class="btn btn-primary shadow-sm" />

                    <a asp-action="Index" asp-route-reporteId="@ViewBag.ReporteId" class="btn btn-outline-secondary shadow-sm ms-2">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}