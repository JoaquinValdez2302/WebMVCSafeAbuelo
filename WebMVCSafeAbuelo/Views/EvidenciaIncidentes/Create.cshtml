@model WebMVCSafeAbuelo.Models.EvidenciaIncidente

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>EvidenciaIncidente</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Tipo" class="control-label fw-bold">Tipo de Evidencia</label>
                <select asp-for="Tipo" class="form-select" asp-items="Html.GetEnumSelectList<WebMVCSafeAbuelo.Models.TipoEvidencia>()">
                    <option value="">-- Seleccione una categoría --</option>
                </select>
                <span asp-validation-for="Tipo" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Valor" class="control-label"></label>
                <input asp-for="Valor" class="form-control" />
                <span asp-validation-for="Valor" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Notas" class="control-label"></label>
                <input asp-for="Notas" class="form-control" />
                <span asp-validation-for="Notas" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ReporteIncidenteId" class="control-label"></label>
                <input asp-for="ReporteIncidenteId" class="form-control" />
                <span asp-validation-for="ReporteIncidenteId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ReporteIncidente" class="control-label"></label>
                <input asp-for="ReporteIncidente" class="form-control" />
                <span asp-validation-for="ReporteIncidente" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}