@{
    ViewData["Title"] = "Crear Cuenta";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm p-4">
                <h3 class="mb-4">Registro en SafeAbuelo</h3>
                
                <div class="mb-3">
                    <label>Nombre Completo</label>
                    <input type="text" id="regNombre" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label>Teléfono (Opcional)</label>
                    <input type="tel" id="regTelefono" class="form-control" />
                </div>
                <hr />
                <div class="mb-3">
                    <label>Correo Electrónico</label>
                    <input type="email" id="regEmail" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label>Contraseña</label>
                    <input type="password" id="regPassword" class="form-control" required />
                </div>
                
                <button id="btnRegistrar" class="btn btn-primary w-100">Crear Cuenta Segura</button>
                <div id="mensajeError" class="text-danger mt-3" style="display:none;"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Vinculamos el archivo externo indicando que es un módulo -->
    <script type="module" src="~/js/registro-firebase.js"></script>
}